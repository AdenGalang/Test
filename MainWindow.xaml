<Window x:Class="PassManaAlpha.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PassManaAlpha"
        xmlns:viewModel="clr-namespace:PassManaAlpha.MVVM.ViewModel"
        mc:Ignorable="d"
        Title="MainWindow" 
        Height="600" 
        Width="930"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        Background="AliceBlue"
        >

    <Window.DataContext>
        <viewModel:MainViewModel/>
    </Window.DataContext>

    <Border Background ="#FF403850" CornerRadius="4">
        <Grid ShowGridLines="False" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="123">

                </ColumnDefinition>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="26">

                </RowDefinition>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <TextBlock
            Text="PassManaAlpha" FontSize="16" Foreground="White" Margin="3,2,0,0" VerticalAlignment="Top" HorizontalAlignment="Left"/>
            <Border BorderThickness="4" CornerRadius="10" Grid.Row="1" Height="500" Background="#643566" Grid.Column="0">
                <StackPanel Grid.Row="1" Height="500" Grid.Column="0">
                    <Button Content="Home" Width="104" Style="{StaticResource LocalTypical}" Height="40" Margin="0,10,0,0" Background="#752f49" Foreground="White" BorderBrush="#FF2D2F38" IsDefault="True" Command="{Binding HomeViewCommand}"/>
                    <Button Content="Passwords" Width="104" Style="{StaticResource LocalTypical}" Height="40" Margin="0,10,0,0" Background="#752f50" Foreground="White" BorderBrush="#FF2D2F38" Command="{Binding PasswordViewCommand}"/>
                    <Button Content="Settings" Width="104" Style="{StaticResource LocalTypical}" Height="40" Margin="0,10,0,0" Background="#752f53" Foreground="White" BorderBrush="#FF2D2F38" Command="{Binding SettingsViewCommand}"/>
                    <Button Content="About" Width="104" Style="{StaticResource LocalTypical}" Height="40" Margin="0,10,0,0" Background="#752f59" Foreground="White" BorderBrush="#FF2D2F38"/>
             </StackPanel>
            </Border>

            


            <ContentControl Grid.Row="1" Grid.Column="1" Margin="3"
                            Content="{Binding CurrentView}">
            </ContentControl>
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
            
        </Grid>

        


    </Border>



</Window>
