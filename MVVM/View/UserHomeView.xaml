<UserControl x:Class="PassManaAlpha.MVVM.View.UserHomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:PassManaAlpha.MVVM.View"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" >
                <TextBlock Text="Welcome to PassManaAlpha!" FontSize="24" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>
                <TextBlock Text="Your secure password manager." FontSize="16" HorizontalAlignment="Center"/>
            <Button  Content="Get Started" Width="150" Height="40" Margin="0,20,0,0" HorizontalAlignment="Center" Style ="{StaticResource LocalTypical}"/>
            </StackPanel>
    </Grid>
</UserControl>
